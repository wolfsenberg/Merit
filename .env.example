# =============================================================================
# Merit Platform - Environment Variables
# Copy this file to .env and fill in production values
# =============================================================================

# --- Application ---
APP_NAME=Merit Platform
APP_VERSION=0.1.0
DEBUG=false
ENVIRONMENT=production

# --- Frontend ---
NEXT_PUBLIC_API_URL=https://your-domain.com/api

# --- Database (PostgreSQL) ---
POSTGRES_USER=merit
POSTGRES_PASSWORD=CHANGE_ME_TO_SECURE_PASSWORD
POSTGRES_DB=merit

# --- Database Connection Pool ---
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# --- Redis ---
REDIS_PASSWORD=CHANGE_ME_TO_SECURE_PASSWORD
REDIS_CACHE_TTL=300

# --- JWT Authentication ---
JWT_SECRET_KEY=CHANGE_ME_TO_RANDOM_SECRET_256_BITS
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- CORS ---
ALLOWED_ORIGINS=["https://your-domain.com"]

# --- File Uploads ---
MAX_UPLOAD_SIZE_MB=10

# --- Rate Limiting ---
RATE_LIMIT_AUTHENTICATED=100
RATE_LIMIT_UNAUTHENTICATED=20

# --- TLS Certificates ---
# Place TLS certificate files in ./certs/ directory:
#   - ./certs/fullchain.pem
#   - ./certs/privkey.pem
# For local development, generate self-signed certs:
#   openssl req -x509 -nodes -days 365 -newkey rsa:2048 \
#     -keyout certs/privkey.pem -out certs/fullchain.pem \
#     -subj "/CN=localhost"

# --- AWS Secrets Manager (Production) ---
# In production, secrets (POSTGRES_PASSWORD, REDIS_PASSWORD, JWT_SECRET_KEY)
# should be fetched from AWS Secrets Manager rather than stored in .env files.
# AWS_REGION=us-east-1
# AWS_SECRET_NAME=merit-platform/production
